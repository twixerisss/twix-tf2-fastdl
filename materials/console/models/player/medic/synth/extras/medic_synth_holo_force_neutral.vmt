"UnLitTwoTexture"
{
	"$basetexture"	"console/models/player/medic/synth/extras/medic_synth_holocol_w"
	"$texture2"	"console/models/player/medic/synth/extras/medic_synth_holoadd_w"
	"$blendtintbybasealpha"		"1"
	"$blendtintcoloroverbase"		"1"
	"$colortint_base"		"{ 122 122 122 }"
	"$color2"		"{ 130 122 122  }"
	"$colortint_tmp"		"[0 0 0]"
	"$additive" "1"
	"$model" "1"

	"$rimlight" "1"						
	"$rimlightexponent" "1"				
	"$rimlightboost" "2"
	"$rimmask" "1"
	
	// Cloaking
	"$cloakPassEnabled" "1"

	"Proxies"
	{
		"invis"
		{
		}

		"TextureScroll"
		{
			"texturescrollvar" "$texture2transform"
			"texturescrollrate" .1
			"texturescrollangle" 90
		}
		"Sine"
		{
			"Sineperiod" ".05"
			"SineMax" "1"
			"SineMin" ".8"
			"resultVar" "$color"
		}
	}
}